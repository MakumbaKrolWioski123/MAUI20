<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MAUI20.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MAUI20"
    Title="MAUI20">
    <TabBar>
        <Tab Title="MAUI 20.2">
            <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
        </Tab>
        <Tab Title="MAUI 20.3">
            <ShellContent
            Title="New Page"
            ContentTemplate="{DataTemplate local:NewPage1}"
            Route="NewPage1" />
        </Tab>
        <Tab Title="MAUI 20.4">
            <ShellContent
            Title="New Page"
            ContentTemplate="{DataTemplate local:NewPage2}"
            Route="NewPage2" />
        </Tab>
    </TabBar>



</Shell>
